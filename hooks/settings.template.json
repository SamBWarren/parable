{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat .claude/rules-card.md 2>/dev/null || true"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat .claude/rules-card.md 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash '{{PROJECT_ROOT}}/.claude/rule-refresh.sh' 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
